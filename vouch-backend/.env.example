  # App
  PORT=5000
  NODE_ENV=development

  # Database
  DATABASE_URL=postgresql://...

  # Auth
  JWT_SECRET=your_long_random_secret_here
  JWT_EXPIRES_IN=7d

  # Squad Sandbox
  SQUAD_API_KEY=your_squad_sandbox_key
  SQUAD_BASE_URL=https://sandbox.squadco.com
  SQUAD_WEBHOOK_SECRET=your_squad_webhook_secret

  # ML Engineer Endpoints
  ML_BASE_URL=http://localhost:0000
  ML_IDENTITY_ENDPOINT=/identity/verify
  ML_FRAUD_ENDPOINT=/fraud/assess

  # IP Analysis (ProxyCheck.io)
  PROXYCHECK_API_KEY=your_proxycheck_api_key

  # Internal
  API_KEY_HEADER=x-api-key